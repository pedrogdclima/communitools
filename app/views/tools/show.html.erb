<h2><%= @tool.name %></h2>
<%= link_to "Back", :back %>


<% if current_user.id != @tool.user_id %>
<div class="">
  <div class="">Owner</div>
  <div class=""><%= @tool.user.name %></div>
</div>
<% end %>

<div class="">
  <div class="">Brand</div>
  <div class=""><%= @tool.brand %></div>
</div>

<div class="row mb-3">
  <div class="col-3">Description</div>
  <div class="col-3"><%= @tool.desc.blank? ? 'No description provided' : @tool.desc %></div>
</div>

<div class="row mb-3">
  <div class="col-3">Photo</div>
  <%= @tool.photo.attached? ? image_tag(@tool.photo) : (tag.div "No photo provided", class: "col-3") %>
</div>

<div class="">
  <div class="">
    <%= link_to "Edit", edit_tool_path(@tool.id) %>
  </div>
  <div class="">
    <%= button_to "Delete", @tool, method: :delete, data: { turbo_confirm: "Are you sure?" } %>
  </div>
</div>
