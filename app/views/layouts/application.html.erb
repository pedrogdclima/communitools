<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Communitools" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>
    
    <!--
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    -->

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <%= yield :head %>
  </head>

  <body class="h-dvh mx-auto max-w-7xl px-6 py-10">
    <header class="mx-auto max-w-2xl">
      <h1>Communitools</h1>
      <div class="flash-container">
        <% if notice %>
          <p class=""><%= notice %></p>
        <% elsif  alert%>
          <p class=""><%= alert %></p>
        <% end %>
      </div>
    </header>
    <main class="mx-auto max-w-2xl mt-10">
      <%= yield %>
    </main>
    <footer class="fixed bottom-0 left-0 right-0 px-6">
      <div class="mx-auto max-w-2xl">
        <div class="">
          <div class="">
            <% if user_signed_in? %>
              <p><%= link_to "Logout", destroy_user_session_path, data: { "turbo-method": :delete } %></p>
            <% elsif current_page?("/about") || current_page?("/") %>
              <p><%= link_to "Login", new_user_session_path %></p>
              <p><%= link_to "Sign Up", new_user_registration_path %></p>
            <% elsif current_page?("/users/sign_up") %>
              <p><%= link_to "Login", new_user_session_path %></p>
            <% elsif current_page?("/users/sign_in") %>
              <p><%= link_to "Sign Up", new_user_registration_path %></p>
            <% end %>
          </div>
          <div class="">
            <a href="https://pedrogdclima.github.io">Built by Pedro</a>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>
