<% content_for :head do %>
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin=""/>
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
  <%= javascript_import_module_tag "slippy_map" %>
<% end %>

<div class="" data-turbo="false">
  <h1 class="">Edit <%= resource_name.to_s.humanize %></h2>
  <%= link_to 'Back', user_path, class: "" %>
</div>

<%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>
  <%= render "devise/shared/error_messages", resource: resource %>

  <div class="field">
    <%= f.label :name, class: "" %>
    <div class="">
      <%= f.text_field :name, class: "", autofocus: true, autocomplete: "name" %>
    </div>
  </div>

  <div class="field">
    <%= f.label :email, class: "" %>
    <div class="">
      <%= f.email_field :email, class: "", autofocus: true, autocomplete: "email" %>
    </div>
  </div>

  <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
    <div  class="">Currently waiting confirmation for: <%= resource.unconfirmed_email %></div>
  <% end %>

  <div class="field">
    <%= f.label :password, class: "" %> <i class="">(new)</i>
    <div class="">
      <%= f.password_field :password, class: "", autocomplete: "new-password" %>
      <!--
      <% if @minimum_password_length %>
        <br />
        <em><%= @minimum_password_length %> characters minimum</em>
      <% end %>
      -->
    </div>
  </div>

  <div class="field">
    <%= f.label :password_confirmation, class: "" %>
    <div class="">
      <%= f.password_field :password_confirmation, class: "", autocomplete: "new-password" %>
    </div>
  </div>

  <div class="field">
    <%= f.label :max_distance, class: "" %>
    <div class="">
      <%= f.number_field :max_distance, in: 1..10, class: "",  autofocus: true, autocomplete: "max-distance" %>
    </div>
  </div>

  <div class="field">
    <%= f.label :latlng, class: "" %>
    <div class="">
      <%= f.text_field :latlng, class: "",  autofocus: true, autocomplete: "latlng" %>
    </div>
  </div>
  <div class="mb-3" style="height: 180px; width: 360px" id="map"></div>

  <div class="field">
    <%= f.label :current_password, class: "" %>
    <!--
    <i>(we need your current password to confirm your changes)</i>
    -->
    <div class="">
      <%= f.password_field :current_password, class: "", autocomplete: "current-password" %>
    </div>
  </div>

  <div class="actions" data-turbo="false">
    <%= f.submit "Update", class: "" %>
  </div>
<% end %>

<div class="">
  <div class="">Delete account?</div>
  <div class="">
    <%= button_to "Delete", registration_path(resource_name), class: "", data: { confirm: "Are you sure?", turbo_confirm: "Are you sure?" }, method: :delete %>
  </div>
</div>